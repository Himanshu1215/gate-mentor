# ── Local LLM (no API key needed — model runs on your machine) ──────────────
# Model: Phi-4-mini-instruct Q4_K_M GGUF (~2.5 GB)
# Download: python scripts/download_models.py
LLM_MODEL_PATH=./models/llm/phi-4-mini-instruct-q4_k_m.gguf

# ── Embedding Model ─────────────────────────────────────────────────────────
# Model: BAAI/bge-base-en-v1.5 (auto-cached on first run)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_CACHE_DIR=./models/embeddings

# ── Database Paths ──────────────────────────────────────────────────────────
DATABASE_PATH=./data/gate_mentor.db
CHROMA_PERSIST_PATH=./data/chroma_db

# ── App Settings ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:5173
